
import React from "react";
import { Button } from "@/components/ui/button";
import { Card } from "@/components/ui/card";
import { Sparkles, Download, Copy, Check, Star } from "lucide-react";
import { Label } from "@/components/ui/label";
import { RadioGroup, RadioGroupItem } from "@/components/ui/radio-group";

export default function LetterPreview({ letter, isGenerating, onGenerate, appealData, language, onPremiumReview, isSaving }) {
  const t = (he, ar) => language === 'he' ? he : ar;
  const [copied, setCopied] = React.useState(false);
  const [service, setService] = React.useState(appealData.review_service || "appeal_expert");

  const handleCopy = () => {
    navigator.clipboard.writeText(letter);
    setCopied(true);
    setTimeout(() => setCopied(false), 2000);
  };

  const handleDownload = () => {
    const element = document.createElement("a");
    const file = new Blob([letter], { type: "text/plain;charset=utf-8" });
    element.href = URL.createObjectURL(file);
    element.download = `${t('ערעור', 'استئناف')}-${appealData.student_name}.txt`;
    document.body.appendChild(element);
    element.click();
    document.body.removeChild(element);
  };

  const isPremium = appealData.is_premium_review;
  const reviewStatus = appealData.status;

  return (
    <div>
      <h2 className="text-2xl font-bold text-slate-900 mb-2">{t("צפייה, ייצוא ושדרוג", "معاينة وتصدير وترقية")}</h2>
      <p className="text-slate-600 mb-6">{t("כאן תוכל ליצור את המכתב, לייצא אותו ולשלוח לבדיקת מומחה", "هنا يمكنك إنشاء الرسالة وتصديرها وإرسالها لمراجعة خبير")}</p>

      {!letter ? (
        <Card className="p-8 text-center border-2 border-dashed border-slate-300">
          <Sparkles className="w-16 h-16 text-blue-500 mx-auto mb-4" />
          <h3 className="text-xl font-semibold text-slate-900 mb-2">
            {t("מוכן ליצור את המכתב?", "هل أنت جاهز لإنشاء الرسالة؟")}
          </h3>
          <p className="text-slate-600 mb-6">
            {t("המערכת תיצור עבורך מכתב ערעור מקצועי ומשכנע", "سيقوم النظام بإنشاء رسالة استئناف احترافية ومقنعة لك")}
          </p>
          <Button
            onClick={onGenerate}
            disabled={isGenerating}
            size="lg"
            className="bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 rounded-xl"
          >
            {isGenerating ? (
              <>
                <div className="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin ml-2"></div>
                {t("מייצר מכתב...", "يتم إنشاء الرسالة...")}
              </>
            ) : (
              <>
                <Sparkles className="w-5 h-5 ml-2" />
                {t("צור מכתב ערעור", "إنشاء رسالة استئناف")}
              </>
            )}
          </Button>
        </Card>
      ) : (
        <div className="space-y-6">
          <Card className="p-6 bg-slate-50">
            <div className="prose prose-slate max-w-none" style={{ direction: language === 'he' ? 'rtl' : 'rtl' }}>
              <div className="whitespace-pre-wrap text-slate-800 leading-relaxed font-sans">
                {letter}
              </div>
            </div>
          </Card>

          <div className="flex flex-wrap gap-3">
            <Button onClick={handleCopy} variant="outline" className="rounded-xl">
              {copied ? <><Check className="w-4 h-4 ml-2" /> {t("הועתק!", "تم النسخ!")}</> : <><Copy className="w-4 h-4 ml-2" /> {t("העתק טקסט", "نسخ النص")}</>}
            </Button>
            <Button onClick={handleDownload} variant="outline" className="rounded-xl">
              <Download className="w-4 h-4 ml-2" /> {t("הורד קובץ", "تنزيل ملف")}
            </Button>
          </div>
          
          <Card className="p-6 bg-gradient-to-r from-amber-50 to-orange-50 border-amber-300">
             <div className="flex flex-col gap-4">
               <div className="flex items-center gap-3">
                 <div className="w-10 h-10 bg-amber-500/10 rounded-full flex items-center justify-center">
                   <Star className="w-5 h-5 text-amber-600"/>
                 </div>
                 <div>
                   <h3 className="font-bold text-lg text-amber-900">{t("שירות פרימיום: בדיקת מומחה", "خدمة بريميوم: مراجعة خبير")}</h3>
                   <p className="text-sm text-amber-800">{t("בחר סוג בדיקה: מומחה ערעורים, יועץ אקדמי, או עו״ד.", "اختر نوع المراجعة: خبير استئناف، مستشار أكاديمي، أو محامٍ.")}</p>
                 </div>
               </div>

               {!isPremium && (
                 <RadioGroup value={service} onValueChange={setService} className="grid md:grid-cols-3 gap-3">
                   <div className="flex items-center gap-2 p-3 rounded-lg border border-amber-200 bg-white/70">
                     <RadioGroupItem id="service-expert" value="appeal_expert" />
                     <Label htmlFor="service-expert" className="cursor-pointer text-sm">
                       {t("מומחה ערעורים", "خبير استئناف")}
                     </Label>
                   </div>
                   <div className="flex items-center gap-2 p-3 rounded-lg border border-amber-200 bg-white/70">
                     <RadioGroupItem id="service-advisor" value="academic_advisor" />
                     <Label htmlFor="service-advisor" className="cursor-pointer text-sm">
                       {t("יועץ אקדמי", "مستشار أكاديمي")}
                     </Label>
                   </div>
                   <div className="flex items-center gap-2 p-3 rounded-lg border border-amber-200 bg-white/70">
                     <RadioGroupItem id="service-lawyer" value="lawyer" />
                     <Label htmlFor="service-lawyer" className="cursor-pointer text-sm">
                       {t("עו״ד (פרו)", "محامٍ (احترافي)")}
                     </Label>
                   </div>
                 </RadioGroup>
               )}

               <div className="flex-shrink-0 w-full md:w-auto">
                  {isPremium ? (
                    <div className="text-center p-2 rounded-lg bg-green-100 text-green-800 font-medium">
                      {t('נשלח לבדיקת מומחה', 'أرسلت للمراجعة')}
                    </div>
                  ) : (
                    <Button onClick={() => onPremiumReview(service)} disabled={isSaving} className="w-full bg-amber-500 hover:bg-amber-600 text-white rounded-xl">
                        {isSaving ? t('שולח...', 'إرسال...') : t('שלח לבדיקה (בתשלום)', 'إرسال للمراجعة (مدفوع)')}
                    </Button>
                  )}
               </div>
             </div>
          </Card>
        </div>
      )}
    </div>
  );
}
